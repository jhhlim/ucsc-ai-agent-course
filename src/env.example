# model provider configuration: "gemini" or "doubleword"
MODEL_PROVIDER=doubleword
#MODEL_PROVIDER=gemini

# Gemini API key and model configuration
GOOGLE_API_KEY="<your key>"
# Use gemini-2.5-flash for stability; preview models may return 503 when busy.
GEMINI_MODEL="gemini-2.5-flash"

#OpenAI API key and model configuration
OPENAI_API_KEY="<your key>"
OPENAI_MODEL="gpt-4o-mini"

# ANTHROPIC_API_KEY API key and model configuration
ANTHROPIC_API_KEY="<your key>"
CLAUDE_MODEL="claude-haiku-4-5-20251001"

# DOUBLEWORD
DOUBLEWORD_API_KEY="<your key>"
DOUBLEWORD_MODEL="openai/Qwen/Qwen3.6-35B-A3B-FP8"
DOUBLEWORD_API_URL="https://api.doubleword.ai/v1"

# LangSmith tracing & evaluation (https://smith.langchain.com)
LANGSMITH_TRACING="true"
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY="<your key>"
LANGSMITH_PROJECT="ucsc-ai-agent-course"
# For HW3 mortgage eval: LANGSMITH_PROJECT="ucsc-hw3-mortgage"

# OpenWeatherMap - current weather and forecast
OPENWEATHER_API_KEY="<your key>"

# ExchangeRate-API - currency conversion
EXCHANGERATE_API_KEY="<your key>"
