# Gemini API key and model configuration
GOOGLE_API_KEY="<your key>"
GEMINI_MODEL="gemini-3-flash-preview"

#OpenAI API key and model configuration
OPENAI_API_KEY="<your key>"
OPENAI_MODEL="gpt-4o-mini"

# ANTHROPIC_API_KEY API key and model configuration
ANTHROPIC_API_KEY="<your key>"
CLAUDE_MODEL="claude-haiku-4-5-20251001"

# DOUBLEWORD
DOUBLEWORD_API_KEY="<your key>"
DOUBLEWORD_MODEL="openai/Qwen/Qwen3.6-35B-A3B-FP8"
DOUBLEWORD_API_URL="https://api.doubleword.ai/v1"

# Model provider switch for multi-agents examples ("gemini" or "doubleword")
MODEL_PROVIDER="gemini"

# LangSmith tracing (used by multi-agents/agent_quality)
LANGSMITH_API_KEY="<your key>"
LANGSMITH_TRACING="true"
LANGSMITH_PROJECT="weather-outfit"